
. "${IRONFOX_MOZCONFIGS}/branding/common.mozconfig"

ac_add_options --disable-ironfox-release
ac_add_options --with-app-basename='IronFox Nightly'
ac_add_options --with-app-name='ironfox-nightly'
ac_add_options --with-branding='ironfox/branding/ironfox-nightly'
readonly MOZ_APP_BASENAME='IronFox Nightly'
readonly MOZ_APP_NAME='ironfox-nightly'
readonly MOZ_APP_REMOTINGNAME='ironfox-nightly'
export MOZ_APP_BASENAME
export MOZ_APP_NAME
export MOZ_APP_REMOTINGNAME
