
. "${IRONFOX_MOZCONFIGS}/branding/common.mozconfig"

ac_add_options --enable-ironfox-release
ac_add_options --with-app-basename='IronFox'
ac_add_options --with-app-name='ironfox'
ac_add_options --with-branding='ironfox/branding/ironfox'
readonly MOZ_APP_BASENAME='IronFox'
readonly MOZ_APP_NAME='ironfox'
readonly MOZ_APP_REMOTINGNAME='ironfox'
export MOZ_APP_BASENAME
export MOZ_APP_NAME
export MOZ_APP_REMOTINGNAME
