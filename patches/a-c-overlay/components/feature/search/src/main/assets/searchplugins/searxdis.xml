<SearchPlugin xmlns="http://www.mozilla.org/2006/browser/search/">
<ShortName>SearXNG (Disroot)</ShortName>
<InputEncoding>UTF-8</InputEncoding>
<Image width="32" height="32">data:image/png;base64,</Image>
<Url type="application/x-suggestions+json" method="POST" template="https://search.disroot.org/autocompleter">
  <Param name="q" value="{searchTerms}"/>
</Url>
<Url type="text/html" method="POST" template="https://search.disroot.org/search">
  <Param name="q" value="{searchTerms}"/>
</Url>
<SearchForm>https://search.disroot.org/</SearchForm>
</SearchPlugin>
